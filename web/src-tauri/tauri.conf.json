{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SAM Enhanced",
  "version": "1.2.1",
  "identifier": "io.github.asdfghj1237890.samenhanced",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Steam 成就管理器",
        "width": 1380,
        "height": 920,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://cdn.cloudflare.steamstatic.com https://cdn.steamstatic.com https://shared.cloudflare.steamstatic.com; connect-src 'self' ipc: http://ipc.localhost https://raw.githubusercontent.com https://store.steampowered.com; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
